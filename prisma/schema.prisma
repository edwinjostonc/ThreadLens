generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SearchCache {
  id              String   @id @default(cuid())
  queryHash       String   @unique
  normalizedQuery String
  report          String   // Full JSON report
  createdAt       DateTime @default(now())
  expiresAt       DateTime

  @@index([queryHash])
  @@index([expiresAt])
}
