# Required — SQLite database path
# For local dev: file:./prisma/dev.db
# For Vercel: file:/tmp/threadlens.db
DATABASE_URL="file:./prisma/dev.db"

# Required — Serper API key for Reddit search via Google (site:reddit.com)
# Free tier: 2,500 searches/month | Get key at: https://serper.dev
# Without this, all searches return empty results
SERPER_API_KEY=""

# Optional — Groq API key for AI-powered explanations & query expansion
# Free tier: 14,400 req/day | Get key at: https://console.groq.com
# Without this, ThreadLens uses template-based explanations (still works!)
GROQ_API_KEY=""

# Optional — Upstash Redis for caching and rate limiting
# Free tier available at: https://upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional — Base URL for JSON-LD schema and sitemap generation
# Set to your production domain (no trailing slash)
NEXT_PUBLIC_BASE_URL="https://thread-lens-gilt.vercel.app"
